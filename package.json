{
  "name": "svn-audit-assistant",
  "displayName": "SVN Audit Assistant",
  "description": "SVN 增量代码审计助手 — 按人员+时间段聚合修改，支持行级批注、覆盖检测和 Markdown 报表导出",
  "version": "0.1.0",
  "publisher": "codereview",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "svnAuditContainer",
          "title": "SVN Audit",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "svnAuditContainer": [
        {
          "id": "svnAuditSidebar",
          "name": "Audit Sessions",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "svnAudit.newSession",
        "title": "SVN Audit: New Review Session",
        "icon": "$(add)"
      },
      {
        "command": "svnAudit.refresh",
        "title": "SVN Audit: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "svnAudit.exportReport",
        "title": "SVN Audit: Export Report",
        "icon": "$(export)"
      },
      {
        "command": "svnAudit.addComment",
        "title": "SVN Audit: Add Comment"
      },
      {
        "command": "svnAudit.markReviewed",
        "title": "SVN Audit: Mark as Reviewed",
        "icon": "$(check)"
      },
      {
        "command": "svnAudit.markFlagged",
        "title": "SVN Audit: Mark as Flagged",
        "icon": "$(warning)"
      },
      {
        "command": "svnAudit.openDiff",
        "title": "SVN Audit: Open Diff View"
      },
      {
        "command": "svnAudit.deleteSession",
        "title": "SVN Audit: Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "svnAudit.addAuthorToSession",
        "title": "SVN Audit: Add Author",
        "icon": "$(person-add)"
      },
      {
        "command": "svnAudit.renameSession",
        "title": "SVN Audit: Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "svnAudit.editComment",
        "title": "SVN Audit: Edit Comment",
        "icon": "$(edit)"
      },
      {
        "command": "svnAudit.deleteComment",
        "title": "SVN Audit: Delete Comment",
        "icon": "$(trash)"
      },
      {
        "command": "svnAudit.exportAuthorReport",
        "title": "SVN Audit: Export Author Report",
        "icon": "$(export)"
      },
      {
        "command": "svnAudit.summarizeAuthor",
        "title": "SVN Audit: Summarize Author",
        "icon": "$(book)"
      },
      {
        "command": "svnAudit.deleteAuthor",
        "title": "SVN Audit: Delete Author",
        "icon": "$(trash)"
      },
      {
        "command": "svnAudit.aiAudit",
        "title": "SVN Audit: AI Code Review",
        "icon": "$(sparkle)"
      },
      {
        "command": "svnAudit.aiAuditSelectModel",
        "title": "SVN Audit: AI Code Review (Select Model)",
        "icon": "$(sparkle)"
      },
      {
        "command": "svnAudit.aiAuditForce",
        "title": "SVN Audit: AI Code Review (Force Default)",
        "icon": "$(sparkle)"
      },
      {
        "command": "svnAudit.openSettings",
        "title": "SVN Audit: Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "svnAudit.newSession.zh",
        "title": "新建审计会话",
        "icon": "$(add)"
      },
      {
        "command": "svnAudit.refresh.zh",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "svnAudit.exportReport.zh",
        "title": "导出报告",
        "icon": "$(export)"
      },
      {
        "command": "svnAudit.openSettings.zh",
        "title": "设置",
        "icon": "$(settings-gear)"
      },
      {
        "command": "svnAudit.aiAudit.zh",
        "title": "AI 代码审查",
        "icon": "$(sparkle)"
      },
      {
        "command": "svnAudit.markReviewed.zh",
        "title": "标记为已审计",
        "icon": "$(check)"
      },
      {
        "command": "svnAudit.markFlagged.zh",
        "title": "标记为需关注",
        "icon": "$(warning)"
      },
      {
        "command": "svnAudit.addAuthorToSession.zh",
        "title": "添加作者",
        "icon": "$(person-add)"
      },
      {
        "command": "svnAudit.renameSession.zh",
        "title": "重命名会话",
        "icon": "$(edit)"
      },
      {
        "command": "svnAudit.deleteSession.zh",
        "title": "删除会话",
        "icon": "$(trash)"
      },
      {
        "command": "svnAudit.addComment.zh",
        "title": "添加代码评论"
      },
      {
        "command": "svnAudit.aiAuditSelectModel.zh",
        "title": "AI 代码审查 (选择模型)",
        "icon": "$(sparkle)"
      },
      {
        "command": "svnAudit.aiAuditForce.zh",
        "title": "AI 代码审查 (强制分析)",
        "icon": "$(sparkle)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "svnAudit.newSession",
          "when": "view == svnAuditSidebar && !svnAudit.isZh",
          "group": "navigation@1"
        },
        {
          "command": "svnAudit.newSession.zh",
          "when": "view == svnAuditSidebar && svnAudit.isZh",
          "group": "navigation@1"
        },
        {
          "command": "svnAudit.refresh",
          "when": "view == svnAuditSidebar && !svnAudit.isZh",
          "group": "navigation@2"
        },
        {
          "command": "svnAudit.refresh.zh",
          "when": "view == svnAuditSidebar && svnAudit.isZh",
          "group": "navigation@2"
        },
        {
          "command": "svnAudit.exportReport",
          "when": "view == svnAuditSidebar && !svnAudit.isZh",
          "group": "navigation@3"
        },
        {
          "command": "svnAudit.exportReport.zh",
          "when": "view == svnAuditSidebar && svnAudit.isZh",
          "group": "navigation@3"
        },
        {
          "command": "svnAudit.openSettings",
          "when": "view == svnAuditSidebar && !svnAudit.isZh",
          "group": "navigation@4"
        },
        {
          "command": "svnAudit.openSettings.zh",
          "when": "view == svnAuditSidebar && svnAudit.isZh",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "svnAudit.markReviewed",
          "when": "view == svnAuditSidebar && viewItem == file && !svnAudit.isZh",
          "group": "inline@1"
        },
        {
          "command": "svnAudit.markReviewed.zh",
          "when": "view == svnAuditSidebar && viewItem == file && svnAudit.isZh",
          "group": "inline@1"
        },
        {
          "command": "svnAudit.markFlagged",
          "when": "view == svnAuditSidebar && viewItem == file && !svnAudit.isZh",
          "group": "inline@2"
        },
        {
          "command": "svnAudit.markFlagged.zh",
          "when": "view == svnAuditSidebar && viewItem == file && svnAudit.isZh",
          "group": "inline@2"
        },
        {
          "command": "svnAudit.aiAudit",
          "when": "view == svnAuditSidebar && viewItem == file && !svnAudit.isZh",
          "group": "inline@3"
        },
        {
          "command": "svnAudit.aiAudit.zh",
          "when": "view == svnAuditSidebar && viewItem == file && svnAudit.isZh",
          "group": "inline@3"
        },
        {
          "command": "svnAudit.exportAuthorReport",
          "when": "view == svnAuditSidebar && viewItem == person && !svnAudit.isZh",
          "group": "inline@1"
        },
        {
          "command": "svnAudit.exportAuthorReport.zh",
          "when": "view == svnAuditSidebar && viewItem == person && svnAudit.isZh",
          "group": "inline@1"
        },
        {
          "command": "svnAudit.deleteAuthor",
          "when": "view == svnAuditSidebar && viewItem == person && !svnAudit.isZh",
          "group": "inline@3"
        },
        {
          "command": "svnAudit.deleteAuthor.zh",
          "when": "view == svnAuditSidebar && viewItem == person && svnAudit.isZh",
          "group": "inline@3"
        },
        {
          "command": "svnAudit.aiAudit",
          "when": "view == svnAuditSidebar && viewItem == person && !svnAudit.isZh",
          "group": "inline@4"
        },
        {
          "command": "svnAudit.aiAudit.zh",
          "when": "view == svnAuditSidebar && viewItem == person && svnAudit.isZh",
          "group": "inline@4"
        },
        {
          "command": "svnAudit.aiAuditSelectModel",
          "when": "view == svnAuditSidebar && (viewItem == person || viewItem == file) && !svnAudit.isZh",
          "group": "6_ai@1"
        },
        {
          "command": "svnAudit.aiAuditSelectModel.zh",
          "when": "view == svnAuditSidebar && (viewItem == person || viewItem == file) && svnAudit.isZh",
          "group": "6_ai@1"
        },
        {
          "command": "svnAudit.aiAuditForce",
          "when": "view == svnAuditSidebar && (viewItem == person || viewItem == file) && !svnAudit.isZh",
          "group": "6_ai@2"
        },
        {
          "command": "svnAudit.aiAuditForce.zh",
          "when": "view == svnAuditSidebar && (viewItem == person || viewItem == file) && svnAudit.isZh",
          "group": "6_ai@2"
        },
        {
          "command": "svnAudit.addAuthorToSession",
          "when": "view == svnAuditSidebar && viewItem == session && !svnAudit.isZh",
          "group": "inline@0"
        },
        {
          "command": "svnAudit.addAuthorToSession.zh",
          "when": "view == svnAuditSidebar && viewItem == session && svnAudit.isZh",
          "group": "inline@0"
        },
        {
          "command": "svnAudit.renameSession",
          "when": "view == svnAuditSidebar && viewItem == session && !svnAudit.isZh",
          "group": "inline@1"
        },
        {
          "command": "svnAudit.renameSession.zh",
          "when": "view == svnAuditSidebar && viewItem == session && svnAudit.isZh",
          "group": "inline@1"
        },
        {
          "command": "svnAudit.deleteSession",
          "when": "view == svnAuditSidebar && viewItem == session && !svnAudit.isZh",
          "group": "inline@2"
        },
        {
          "command": "svnAudit.deleteSession.zh",
          "when": "view == svnAuditSidebar && viewItem == session && svnAudit.isZh",
          "group": "inline@2"
        }
      ],
      "editor/context": [
        {
          "command": "svnAudit.addComment",
          "when": "resourceScheme == 'svn-audit' && !svnAudit.isZh",
          "group": "svnAudit@1"
        },
        {
          "command": "svnAudit.addComment.zh",
          "when": "resourceScheme == 'svn-audit' && svnAudit.isZh",
          "group": "svnAudit@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "svnAudit.addComment",
        "key": "enter",
        "when": "resourceScheme == 'svn-audit' && editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src --ext ts",
    "test": "jest"
  },
  "dependencies": {
    "sql.js": "^1.10.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "@types/xml2js": "^0.4.14",
    "typescript": "^5.3.3",
    "esbuild": "^0.20.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  }
}